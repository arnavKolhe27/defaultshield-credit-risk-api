# Ignore python virtual environments (huge folders with thousands of external libraries)
.venv/
venv/
env/

# Ignore compiled Python bytecode (junk caching files generated by running your API)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Ignore local configuration files where secrets are hidden
.env
local_settings.py

# Ignore operating system specific desktop layout files
.DS_Store
Thumbs.db